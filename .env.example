# =============================================================================
# FastTravel — environment variables
# Copy to .env and fill in. NEVER commit .env (it is in .gitignore).
# =============================================================================

# --- Environment ---
ENVIRONMENT=dev            # dev | staging | prod
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR

# --- Postgres ---
POSTGRES_USER=fasttravel
POSTGRES_PASSWORD=fasttravel_dev_change_me
POSTGRES_DB=fasttravel
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Composite URL used by SQLAlchemy / Alembic
DATABASE_URL=postgresql+asyncpg://fasttravel:fasttravel_dev_change_me@postgres:5432/fasttravel
# Sync variant (for Alembic offline mode / scripts)
DATABASE_URL_SYNC=postgresql+psycopg://fasttravel:fasttravel_dev_change_me@postgres:5432/fasttravel

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3100,http://127.0.0.1:3100,https://fasttravel.com.ua

# --- Production image overrides (set by CI deploy workflow) ---
API_IMAGE=
BOT_IMAGE=
SCHEDULER_IMAGE=

# --- Telegram (bot, populated later) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
# Separate private/operator chat for Prometheus AlertManager notifications.
# Do not set this to TELEGRAM_CHANNEL_ID; the public deals group must only
# receive tour posts.
TELEGRAM_ALERTS_CHAT_ID=

# --- Public links (used in bot CTA buttons + deep links) ---
PUBLIC_CHANNEL_LINK=https://t.me/fasttravel_deals
PUBLIC_SITE_URL=https://fasttravel.com.ua

# --- ittour API (populated when token issued) ---
ITTOUR_API_BASE=https://api.ittour.com.ua
ITTOUR_API_TOKEN=

# --- TBO Holidays ---
TBO_API_BASE=https://api.tbotechnology.in/TBOHolidays_HotelAPI
TBO_USERNAME=
TBO_PASSWORD=

# --- Observability (optional) ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# Sprint 1-3 feature flags + tuning. All optional; defaults shipped in code.
# =============================================================================

# Sprint 1C — static_tours_sweep ingest job (operator-flagged promos).
# Default OFF. Set to "1" / "true" once you've verified the first run
# manually (see docs/farvater-har-report.md for the canonical bucket list).
FT_STATIC_TOURS_SWEEP_ENABLED=

# Sprint 1D — optional promo-discount branch. Reads from promo_offers but
# must only insert deals when Farvater emits a real strike-through
# (red_price_uah > price_uah). Keep OFF by default.
FT_DEAL_DETECTION_BUCKETS_ENABLED=

# Sprint 1F — decay_active_prices threshold (days). Hotels whose
# last_priced_at is older than this get has_active_prices=FALSE and
# drop out of /search. Default 7.
DECAY_STALE_AFTER_DAYS=7

# Sprint 3.1 — snapshot_farvater wall-clock budget (minutes). After
# this elapses the run records `status='partial'` instead of dragging
# into the next scheduled tick. Default 300 (5h, fits 12h tick spacing
# with 7h headroom).
FT_SNAPSHOT_MAX_RUNTIME_MINUTES=0
# Bound each 12h price snapshot to a rotating slice per country. Set 0 for
# all hotels, but that can exceed the 5h runtime budget on the current catalog.
FT_SNAPSHOT_MAX_HOTELS_PER_COUNTRY=0

# Shared secret the bot's /alerts webhook expects in either the
# `X-Webhook-Secret` header or `Authorization: Bearer <secret>`.
#
# REQUIRED IN PROD (Settings.assert_prod_secrets refuses to start the bot
# without it; the /alerts handler also returns 503 if it's unset in prod).
# In dev, leaving it empty makes the webhook accept unsigned requests.
#
# Generate with: openssl rand -hex 32
# Put the same value in infra/prometheus/.webhook_secret so AlertManager
# can authenticate against the bot.
ALERTMANAGER_WEBHOOK_SECRET=
