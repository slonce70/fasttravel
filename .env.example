# =============================================================================
# FastTravel — environment variables
# Copy to .env and fill in. NEVER commit .env (it is in .gitignore).
# =============================================================================

# --- Environment ---
ENVIRONMENT=dev            # dev | staging | prod
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR

# --- Postgres ---
POSTGRES_USER=fasttravel
POSTGRES_PASSWORD=fasttravel_dev_change_me
POSTGRES_DB=fasttravel
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Composite URL used by SQLAlchemy / Alembic
DATABASE_URL=postgresql+asyncpg://fasttravel:fasttravel_dev_change_me@postgres:5432/fasttravel
# Sync variant (for Alembic offline mode / scripts)
DATABASE_URL_SYNC=postgresql+psycopg://fasttravel:fasttravel_dev_change_me@postgres:5432/fasttravel

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100,https://fasttravel.com.ua
# Optional trusted proxy headers for API rate-limit keying. Empty uses the
# code default: CF-Connecting-IP,X-Forwarded-For. Override only when a
# different trusted proxy chain is in front of the API.
RATE_LIMIT_TRUSTED_HEADER=

# --- Production image overrides (set by CI deploy workflow) ---
API_IMAGE=
BOT_IMAGE=
SCHEDULER_IMAGE=

# --- Telegram (bot, populated later) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
# Separate private/operator chat for Prometheus AlertManager notifications.
# Do not set this to TELEGRAM_CHANNEL_ID; the public deals group must only
# receive tour posts.
TELEGRAM_ALERTS_CHAT_ID=
# Public channel daily deal cap (anti-spam default). Set 0 only for an
# explicit unlimited operator run; per-tick pacing still comes from
# DEALS_PER_POST_TICK and TELEGRAM_SEND_DELAY_SECONDS.
DEALS_DAILY_CAP=30

# --- Public links (used in bot CTA buttons + deep links) ---
PUBLIC_CHANNEL_LINK=https://t.me/fasttravel_deals
PUBLIC_SITE_URL=https://fasttravel.com.ua

# --- ittour API (populated when token issued) ---
ITTOUR_API_BASE=https://api.ittour.com.ua
ITTOUR_API_TOKEN=

# --- TBO Holidays ---
TBO_API_BASE=https://api.tbotechnology.in/TBOHolidays_HotelAPI
TBO_USERNAME=
TBO_PASSWORD=

# --- Observability (optional) ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# Sprint 1-3 feature flags + tuning. All optional; defaults shipped in code.
# =============================================================================

# Sprint 1C — static_tours_sweep ingest job (operator-flagged promos).
# Default OFF. Set to "1" / "true" once you've verified the first run
# manually (see docs/farvater-har-report.md for the canonical bucket list).
FT_STATIC_TOURS_SWEEP_ENABLED=

# Sprint 1D — optional promo-discount branch. Reads from promo_offers but
# must only insert deals when Farvater emits a real strike-through
# (red_price_uah > price_uah). Keep OFF by default.
FT_DEAL_DETECTION_BUCKETS_ENABLED=

# Sprint 1F — decay_active_prices threshold (days). Hotels whose
# last_priced_at is older than this get has_active_prices=FALSE and
# drop out of /search. Default 7.
DECAY_STALE_AFTER_DAYS=7

# Sprint 3.1 — snapshot_farvater wall-clock budget (minutes). After
# this elapses the run records `status='partial'` instead of dragging
# into the next scheduled tick. Default 300 (5h, fits 12h tick spacing
# with 7h headroom).
FT_SNAPSHOT_MAX_RUNTIME_MINUTES=0
# Bound each 12h price snapshot to a rotating slice per country. Set 0 for
# all hotels, but that can exceed the 5h runtime budget on the current catalog.
FT_SNAPSHOT_MAX_HOTELS_PER_COUNTRY=0
# Farvater snapshot job fan-out. Keep at 3 unless runtime evidence shows
# upstream and DB can handle more. In the snapshot job, this also becomes the
# HTTP-client concurrency fallback unless FT_FARVATER_HTTP_CONCURRENCY is set.
FT_FARVATER_CONCURRENCY=3
# Farvater HTTP-client concurrency. Set explicitly when you need it to differ
# from snapshot job fan-out. Keep aligned with upstream tolerance.
FT_FARVATER_HTTP_CONCURRENCY=3
# Daily Farvater request cap. 0 means unlimited; set a cap to avoid upstream
# pressure during recovery or catalog expansion.
FT_FARVATER_DAILY_CAP=0
# Farvater HTTP request timeout in seconds.
FT_FARVATER_HTTP_TIMEOUT_S=30.0
# Production Farvater throttle. 0.05 ~= up to 20 request starts/sec; circuit
# breaker still stops the run on repeated 429/403 responses.
FT_FARVATER_HTTP_MIN_INTERVAL_S=0.05
# Extra per-hotel/request sleep. Keep 0 unless deliberately slowing recovery.
FT_FARVATER_REQUEST_DELAY_S=0
# Disabled by default: this is a heavy long-tail sitemap pass and should not
# auto-run after every scheduler restart/deploy. Set to 1 only for manual
# recovery when you intentionally want startup resume.
FT_SITEMAP_STARTUP_INGEST_ENABLED=
# Long-tail sitemap ingest concurrency and per-request delay. Lower these
# before increasing startup ingest pressure.
FT_SITEMAP_INGEST_CONCURRENCY=12
FT_SITEMAP_INGEST_DELAY_S=0.05

# AlertManager → bot /alerts webhook. Off by default; turn on together with
# the `observability` docker-compose profile (which runs AlertManager). With
# it off, the bot binds no webhook port and the secret below is not required.
ALERT_WEBHOOK_ENABLED=

# Shared secret the bot's /alerts webhook expects in either the
# `X-Webhook-Secret` header or `Authorization: Bearer <secret>`.
#
# REQUIRED IN PROD WHEN ALERT_WEBHOOK_ENABLED=true (Settings.assert_prod_secrets
# refuses to start the bot without it; the /alerts handler also returns 503 if
# it's unset in prod). In dev, leaving it empty makes the webhook accept
# unsigned requests.
#
# Generate with: openssl rand -hex 32
# Put the same value in infra/prometheus/.webhook_secret so AlertManager
# can authenticate against the bot.
ALERTMANAGER_WEBHOOK_SECRET=
