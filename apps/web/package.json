{
  "name": "@fasttravel/web",
  "version": "0.1.0",
  "private": true,
  "description": "FastTravel — Next.js 15 frontend on Cloudflare Pages",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:preview": "wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "pages:deploy": "pnpm pages:build && wrangler pages deploy .vercel/output/static"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "date-fns": "^4.1.0",
    "next": "15.0.3",
    "react": "19.0.0-rc-66855b96-20241106",
    "react-day-picker": "^9.4.0",
    "react-dom": "19.0.0-rc-66855b96-20241106",
    "recharts": "^2.13.3"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.5",
    "@tanstack/react-query-devtools": "^5.59.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "15.0.3",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "wrangler": "^3.86.1"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
