{
  "name": "@fasttravel/web",
  "version": "0.1.0",
  "private": true,
  "description": "FastTravel — Next.js 15 frontend on Cloudflare Workers via OpenNext",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "predev": "node scripts/clean-next-dev-cache.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare deploy --env=\"\"",
    "cf:deploy:preview": "opennextjs-cloudflare deploy --env preview",
    "cf:upload": "opennextjs-cloudflare upload --env=\"\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "date-fns": "^4.4.0",
    "next": "15.5.18",
    "react": "^19.0.0",
    "react-day-picker": "^9.4.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.14.0",
    "eslint-config-next": "15.5.18",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.16"
    }
  }
}
